[0.559, "o", "\u001b[1mBasic Setup\u001b[22m\r\n\r\n\u001b[2m```typescript\u001b[22m\r\n\u001b[36mconst server = Bun.serve({\u001b[39m\r\n\u001b[36m  // `routes` requires Bun v1.2.3+\u001b[39m\r\n\u001b[36m  routes: {\u001b[39m\r\n\u001b[36m    // Static routes\u001b[39m\r\n\u001b[36m    \"/api/status\": new Response(\"OK\"),\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36m    // Dynamic routes\u001b[39m\r\n\u001b[36m    \"/users/:id\": req => {\u001b[39m\r\n\u001b[36m      return new Response(`Hello User ${req.params.id}!`);\u001b[39m\r\n\u001b[36m    },\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36m    // Per-HTTP method handlers\u001b[39m\r\n\u001b[36m    \"/api/posts\": {\u001b[39m\r\n\u001b[36m      GET: () => new Response(\"List posts\"),\u001b[39m\r\n\u001b[36m      POST: async req => {\u001b[39m\r\n\u001b[36m        const body = await req.json();\u001b[39m\r\n\u001b[36m        return Response.json({ created: true, ...body });\u001b[39m\r\n\u001b[36m      },\u001b[39m\r\n\u001b[36m    },\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36m    // Wildcard route for all routes that start with \"/api/\" and aren't otherwise matched\u001b[39m\r\n\u001b[36m    \"/api/*\": Response.json({ message: \"Not found\" }, { status: 404 }),\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36m    // Redirect from /blog/hello to /blog/hello/world\u001b[39m\r\n\u001b[36m "]
[0.000, "o", "   \"/blog/hello\": Response.redirect(\"/blog/hello/world\"),\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36m    // Serve a file by lazily loading it into memory\u001b[39m\r\n\u001b[36m    \"/favicon.ico\": Bun.file(\"./favicon.ico\"),\u001b[39m\r\n\u001b[36m  },\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36m  // (optional) fallback for unmatched routes:\u001b[39m\r\n\u001b[36m  // Required if Bun's version < 1.2.3\u001b[39m\r\n\u001b[36m  fetch(req) {\u001b[39m\r\n\u001b[36m    return new Response(\"Not Found\", { status: 404 });\u001b[39m\r\n\u001b[36m  },\u001b[39m\r\n\u001b[36m});\u001b[39m\r\n\u001b[36m\u001b[39m\r\n\u001b[36mconsole.log(`Server running at ${server.url}`);\u001b[39m\r\n\u001b[2m```\u001b[22m\r\n\r\n\u001b[2m* \u001b[22m* *\r\n"]
