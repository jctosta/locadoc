[0.516, "o", "\u001b[36mbun\u001b[39m  CSRF Protection: Using with Bun.serve()                                   \u001b[2mruntime/csrf#using-with-bun-serve\u001b[22m                                           \u001b[35mruntime\u001b[39m  \u001b[2m(96)\u001b[22m\r\n\u001b[36mbun\u001b[39m  Build an HTTP server using Elysia and Bun                                 \u001b[2mguides/ecosystem/elysia\u001b[22m                                                     \u001b[35mguides\u001b[39m   \u001b[2m(81)\u001b[22m\r\n\u001b[36mbun\u001b[39m  Build an HTTP server using Express and Bun                                \u001b[2mguides/ecosystem/express\u001b[22m                                                    \u001b[35mguides\u001b[39m   \u001b[2m(81)\u001b[22m\r\n\u001b[36mbun\u001b[39m  Build an HTTP server using Hono and Bun                                   \u001b[2mguides/ecosystem/hono\u001b[22m                                                       \u001b[35mguides\u001b[39m   \u001b[2m(81)\u001b[22m\r\n\u001b[36mbun\u001b[39m  Build an HTTP server using StricJS and Bun                                \u001b[2mguides/ecosystem/stric\u001b[22m                                                      \u001b[35mguides\u001b[39m  "]
